rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    /**
     * documentGenerator.buildStoragePath, evidence, audit-packages 모두
     * workspaces/{workspaceId}/... 하위만 사용함.
     */
    match /workspaces/{workspaceId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == workspaceId;
    }
  }
}
